<IfModule mod_rewrite.c>
    RewriteEngine On

    # Shared hosting document roots often point at the Laravel project root.
    # Route all public requests into Laravel's public directory.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>
